{
	"compatibility_date": "2026-04-04",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "blockwork",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "blockwork-db",
			"database_id": "609dea2a-5b46-426a-ab60-8e6b7a51014d"
		}
	]
}