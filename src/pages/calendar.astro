---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCalendarWeeks } from '../lib/data';
import { Calendar } from '../components/calendar/Calendar';
import { TYPE_COLORS } from '../lib/types';

// Load 20 weeks back (full training history visible)
const weeks = getCalendarWeeks(20);
const today = new Date().toISOString().slice(0, 10);
---

<BaseLayout title="Calendar" active="calendar">
  <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold tracking-tight mb-1">Training Calendar</h1>
      <p class="text-text-secondary text-sm">Click any day for full details + feedback</p>
    </div>
    <div class="flex items-center gap-2 text-[10px] flex-wrap">
      {Object.entries(TYPE_COLORS).map(([type, color]) => (
        <span class="flex items-center gap-1 px-2 py-0.5 rounded-full" style={`background: ${color}10;`}>
          <span class="w-1.5 h-1.5 rounded-full" style={`background: ${color};`}></span>
          <span class="text-text-muted capitalize">{type}</span>
        </span>
      ))}
    </div>
  </div>

  <Calendar client:load weeks={weeks} today={today} />

  <script is:inline>
    try {
      var u = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
      if (!u.email || u.exp < Date.now()) window.location.href = '/';
    } catch(e) { window.location.href = '/'; }
  </script>
</BaseLayout>
