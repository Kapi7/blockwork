---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';
import { getCalendarWeeks } from '../lib/data';
import { formatPace, formatDate, formatDistance, formatTime } from '../lib/format';
import { TYPE_COLORS, PHASE_COLORS } from '../lib/types';

const weeks = getCalendarWeeks(6);
const today = new Date().toISOString().slice(0, 10);
const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
---

<BaseLayout title="Calendar" active="calendar">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold mb-1">Training Calendar</h1>
      <p class="text-text-secondary text-sm">Planned sessions vs actual activities</p>
    </div>
    <div class="flex gap-2">
      <div class="flex items-center gap-3 text-xs">
        {Object.entries(TYPE_COLORS).map(([type, color]) => (
          <span class="flex items-center gap-1">
            <span class="w-2.5 h-2.5 rounded-sm" style={`background: ${color};`}></span>
            <span class="text-text-muted capitalize">{type}</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Calendar Grid -->
  <div class="space-y-1">
    <!-- Day headers -->
    <div class="grid grid-cols-8 gap-1">
      <div class="text-xs text-text-muted p-2">Week</div>
      {dayNames.map((d) => (
        <div class="text-xs text-text-muted font-medium p-2 text-center">{d}</div>
      ))}
    </div>

    <!-- Weeks -->
    {weeks.map((week) => {
      const weekPhase = week.find((d) => d.phase)?.phase;
      const weekBlock = week.find((d) => d.blockName)?.blockName;
      const phaseColor = PHASE_COLORS[weekPhase || ''] || '#747d8c';

      // Weekly totals
      const plannedKm = week.reduce((sum, d) => sum + (d.session?.planned.distance || 0), 0);
      const actualKm = week.reduce((sum, d) => {
        const runActivities = d.activities.filter((a) => a.type === 'Run' || a.type === 'VirtualRun');
        return sum + runActivities.reduce((s, a) => s + a.dist, 0);
      }, 0);

      const weekDate = week[0]?.date;
      const weekLabel = weekDate ? new Date(weekDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '';

      return (
        <div class="grid grid-cols-8 gap-1">
          {/* Week label */}
          <div class="rounded-lg bg-bg-card/50 p-2 flex flex-col justify-between border-l-2" style={`border-color: ${phaseColor};`}>
            <div>
              <div class="text-xs font-mono text-text-muted">{weekLabel}</div>
              {weekBlock && <div class="text-xs text-text-secondary mt-0.5 truncate">{weekBlock}</div>}
            </div>
            <div class="mt-1">
              {plannedKm > 0 && (
                <div class="text-xs font-mono">
                  <span class={actualKm >= plannedKm * 0.8 ? 'text-type-easy' : actualKm > 0 ? 'text-type-steady' : 'text-text-muted'}>
                    {Math.round(actualKm)}
                  </span>
                  <span class="text-text-muted">/{Math.round(plannedKm)}km</span>
                </div>
              )}
              {plannedKm === 0 && actualKm > 0 && (
                <div class="text-xs font-mono text-text-secondary">{Math.round(actualKm)}km</div>
              )}
            </div>
          </div>

          {/* Day cells */}
          {week.map((day) => {
            const isToday = day.date === today;
            const isPast = day.date < today;
            const hasSession = !!day.session;
            const hasActual = day.activities.length > 0;
            const typeColor = hasSession ? (TYPE_COLORS[day.session!.type] || '#747d8c') : '#747d8c';
            const dayNum = new Date(day.date).getDate();
            const matched = day.session?.actual;
            const missed = hasSession && isPast && !matched && day.session!.type !== 'rest';

            // Unplanned activities (not matched to any session)
            const extraActivities = hasActual && !hasSession ? day.activities : [];

            return (
              <div
                class:list={[
                  'rounded-lg border min-h-[100px] p-1.5 flex flex-col transition-all relative group',
                  isToday ? 'border-accent/50 bg-accent/5 shadow-[0_0_12px_rgba(0,212,170,0.15)]' : 'border-border-subtle bg-bg-card/40',
                  hasSession ? 'hover:bg-bg-card-hover cursor-default' : '',
                ]}
              >
                {/* Day number */}
                <div class="flex items-center justify-between mb-1">
                  <span class:list={[
                    'text-xs font-mono',
                    isToday ? 'text-accent font-bold' : 'text-text-muted',
                  ]}>
                    {dayNum}
                  </span>
                  {hasSession && (
                    <span class="w-2 h-2 rounded-full" style={`background: ${typeColor};`}></span>
                  )}
                </div>

                {/* Planned session */}
                {hasSession && (
                  <div class="flex-1">
                    <div class="text-xs font-medium leading-tight truncate" style={`color: ${typeColor};`}>
                      {day.session!.planned.desc}
                    </div>
                    {day.session!.planned.distance > 0 && (
                      <div class="text-xs text-text-muted mt-0.5 font-mono">
                        {day.session!.planned.distance}km
                      </div>
                    )}
                    {day.session!.planned.pace && day.session!.type !== 'rest' && (
                      <div class="text-xs text-text-muted truncate">
                        {day.session!.planned.pace}
                      </div>
                    )}
                  </div>
                )}

                {/* Actual activity overlay */}
                {matched && (
                  <div class="mt-auto pt-1 border-t border-border-subtle">
                    <div class="flex items-center gap-1">
                      <span class="text-xs text-type-easy">&#10003;</span>
                      <span class="text-xs font-mono text-text-primary">{formatDistance(matched.dist)}km</span>
                    </div>
                    <div class="text-xs font-mono text-text-secondary">
                      {formatPace(matched.pace)}
                      {matched.hr > 0 && ` ${Math.round(matched.hr)}bpm`}
                    </div>
                  </div>
                )}

                {/* Missed indicator */}
                {missed && (
                  <div class="mt-auto">
                    <span class="text-xs text-type-key/60">missed</span>
                  </div>
                )}

                {/* Unplanned activities */}
                {extraActivities.length > 0 && (
                  <div class="flex-1 flex flex-col">
                    {extraActivities.slice(0, 2).map((a) => (
                      <div class="text-xs">
                        <span class="font-mono text-text-secondary">{formatDistance(a.dist)}km</span>
                        <span class="text-text-muted ml-1">{formatPace(a.pace)}</span>
                      </div>
                    ))}
                    {extraActivities.length > 2 && (
                      <span class="text-xs text-text-muted">+{extraActivities.length - 2} more</span>
                    )}
                  </div>
                )}

                {/* Hover tooltip with notes */}
                {hasSession && day.session!.planned.notes && (
                  <div class="absolute z-10 bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 bg-bg-card border border-border-subtle rounded-md shadow-lg text-xs text-text-secondary max-w-[200px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                    {day.session!.planned.notes}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      );
    })}
  </div>

  {/* Legend */}
  <div class="mt-4 flex items-center gap-4 text-xs text-text-muted">
    <span class="flex items-center gap-1"><span class="text-type-easy">&#10003;</span> Completed</span>
    <span class="flex items-center gap-1"><span class="text-type-key/60">missed</span> Missed</span>
    <span class="flex items-center gap-1">
      <span class="w-3 h-3 rounded border border-accent/50 bg-accent/5"></span> Today
    </span>
  </div>
</BaseLayout>
