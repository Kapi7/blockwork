---
import '../styles/global.css';
const GOOGLE_CLIENT_ID = '129231084858-u9lh367qrq8fr5dd68aqenffiutnb4k5.apps.googleusercontent.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blockwork</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
      body { background: #050508; color: #eef0f6; font-family: 'Outfit', sans-serif; }
      .hero-glow {
        position: absolute;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(0,229,176,0.07) 0%, transparent 70%);
        top: 10%; left: 50%; transform: translateX(-50%);
        pointer-events: none;
      }
      .hero-glow-2 {
        position: absolute;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(52,152,255,0.04) 0%, transparent 70%);
        top: 40%; right: 10%;
        pointer-events: none;
      }
      @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
      .float { animation: float 6s ease-in-out infinite; }
      @keyframes fade-up { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
      .fade-up { animation: fade-up 0.8s ease-out forwards; opacity: 0; }
      .fade-up-1 { animation-delay: 0.1s; }
      .fade-up-2 { animation-delay: 0.3s; }
      .fade-up-3 { animation-delay: 0.5s; }
      .fade-up-4 { animation-delay: 0.7s; }
    </style>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <div class="hero-glow"></div>
    <div class="hero-glow-2"></div>

    <!-- Nav -->
    <nav class="fixed top-0 inset-x-0 z-50">
      <div class="mx-auto max-w-5xl px-6 flex h-16 items-center justify-between">
        <div class="flex items-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.9"/>
            <rect x="14" y="2" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.4"/>
            <rect x="2" y="14" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.4"/>
            <rect x="14" y="14" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.15"/>
          </svg>
          <span class="text-sm font-bold tracking-tight">blockwork</span>
        </div>
        <div id="gsiBtn">
          <div id="g_id_onload"
            data-client_id={GOOGLE_CLIENT_ID}
            data-callback="handleGoogleLogin"
            data-auto_prompt="false">
          </div>
          <div class="g_id_signin"
            data-type="standard"
            data-shape="pill"
            data-theme="filled_black"
            data-text="signin_with"
            data-size="medium">
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative min-h-screen flex items-center justify-center px-6">
      <div class="max-w-2xl text-center">
        <div class="fade-up fade-up-1 inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[rgba(0,229,176,0.15)] text-[#00e5b0] text-[11px] font-semibold tracking-[0.15em] uppercase mb-10">
          <span class="w-1.5 h-1.5 rounded-full bg-[#00e5b0]" style="animation: pulse-glow 2s ease-in-out infinite;"></span>
          Structured Training
        </div>

        <h1 class="fade-up fade-up-2 text-[clamp(2.5rem,8vw,5.5rem)] font-black leading-[0.95] tracking-[-0.03em] mb-6">
          Every block<br/>
          <span style="background:linear-gradient(135deg,#00e5b0,#3498ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">builds you.</span>
        </h1>

        <p class="fade-up fade-up-3 text-[#7c8495] text-base sm:text-lg max-w-md mx-auto mb-12 leading-relaxed font-light">
          AI coaching with block periodization.<br/>
          Your Strava data. Your goals. Structured progress.
        </p>

        <div class="fade-up fade-up-4 flex flex-col items-center gap-6">
          <a
            href="/dashboard"
            class="group inline-flex items-center gap-2.5 px-10 py-4 rounded-2xl bg-[#00e5b0] text-[#050508] font-semibold text-sm tracking-wide hover:shadow-[0_0_40px_rgba(0,229,176,0.25)] transition-all duration-300"
          >
            Start Training
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Stats ribbon -->
    <section class="border-t border-b border-[rgba(255,255,255,0.04)] py-16 px-6">
      <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold tracking-tight" style="font-family:'DM Mono',monospace;color:#00e5b0;">1,408</div>
          <div class="text-[11px] text-[#3d4350] mt-1.5 font-medium tracking-[0.1em] uppercase">Activities</div>
        </div>
        <div>
          <div class="text-3xl font-bold tracking-tight" style="font-family:'DM Mono',monospace;">6</div>
          <div class="text-[11px] text-[#3d4350] mt-1.5 font-medium tracking-[0.1em] uppercase">Sport Types</div>
        </div>
        <div>
          <div class="text-3xl font-bold tracking-tight" style="font-family:'DM Mono',monospace;">80/20</div>
          <div class="text-[11px] text-[#3d4350] mt-1.5 font-medium tracking-[0.1em] uppercase">Polarized</div>
        </div>
        <div>
          <div class="text-3xl font-bold tracking-tight" style="font-family:'DM Mono',monospace;color:#0be881;">Live</div>
          <div class="text-[11px] text-[#3d4350] mt-1.5 font-medium tracking-[0.1em] uppercase">Strava Sync</div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-4">
        {[
          { icon: '&#x1F9E0;', title: 'AI Block Design', desc: 'Claude generates 2-3 week training blocks based on your fitness, goals, and recovery status.', color: '#00e5b0' },
          { icon: '&#x26A1;', title: 'Live Readiness', desc: 'ATL, CTL, TSB computed daily. Know when to push hard and when to back off.', color: '#3498ff' },
          { icon: '&#x1F4AC;', title: 'Coach Feedback Loop', desc: 'Log RPE and notes after every session. Your coach gets full context for the next block.', color: '#a55eea' },
        ].map((f) => (
          <div class="rounded-2xl bg-[rgba(14,14,26,0.6)] border border-[rgba(255,255,255,0.04)] p-7 hover:border-[rgba(255,255,255,0.08)] transition-colors">
            <div class="text-2xl mb-5" set:html={f.icon}></div>
            <h3 class="text-base font-semibold mb-2">{f.title}</h3>
            <p class="text-sm text-[#7c8495] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <footer class="py-10 px-6 text-center border-t border-[rgba(255,255,255,0.04)]">
      <p class="text-[11px] text-[#3d4350] tracking-wider">blockwork &mdash; structure without rigidity</p>
    </footer>

    <script is:inline>
      function handleGoogleLogin(response) {
        var parts = response.credential.split('.');
        var payload = JSON.parse(atob(parts[1]));
        localStorage.setItem('blockwork_user', JSON.stringify({
          email: payload.email, name: payload.name, picture: payload.picture,
          role: payload.email === 'kapoosha@gmail.com' ? 'coach' : 'athlete',
          exp: Date.now() + 30 * 24 * 60 * 60 * 1000,
        }));
        window.location.href = '/dashboard';
      }
      window.handleGoogleLogin = handleGoogleLogin;
      try {
        var u = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
        if (u.email && u.exp > Date.now()) window.location.href = '/dashboard';
      } catch(e) {}
    </script>
  </body>
</html>
