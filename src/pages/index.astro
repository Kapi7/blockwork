---
import '../styles/global.css';

const user = (Astro.locals as any).user;
// If logged in, redirect to dashboard
if (user) return Astro.redirect('/dashboard');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blockwork — Training Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-bg-main text-text-primary">
    <!-- Nav -->
    <nav class="fixed top-0 inset-x-0 z-50 border-b border-border-subtle bg-bg-main/80 backdrop-blur-xl">
      <div class="mx-auto max-w-6xl px-6 flex h-16 items-center justify-between">
        <span class="text-xl font-extrabold text-accent tracking-tight">BLOCKWORK</span>
        <a
          href="/api/auth/login"
          class="px-5 py-2 rounded-full bg-accent text-bg-main text-sm font-semibold hover:bg-accent-dim transition-colors"
        >
          Sign in with Google
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="pt-32 pb-20 px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 text-accent text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          Block-based periodization
        </div>
        <h1 class="text-5xl sm:text-6xl font-extrabold leading-tight mb-6">
          Train smarter.<br/>
          <span class="text-accent">Race faster.</span>
        </h1>
        <p class="text-lg text-text-secondary max-w-xl mx-auto mb-10">
          AI-powered coaching platform for runners and cyclists.
          Structured training blocks, Strava sync, real-time analytics,
          and a coach that adapts to your progress.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/api/auth/login"
            class="flex items-center gap-3 px-8 py-3.5 rounded-xl bg-white text-gray-800 font-semibold text-sm hover:bg-gray-100 transition-colors shadow-lg shadow-white/10"
          >
            <svg width="20" height="20" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google
          </a>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 px-6 border-t border-border-subtle">
      <div class="mx-auto max-w-5xl">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="rounded-2xl bg-bg-card border border-border-subtle p-6">
            <div class="w-10 h-10 rounded-xl bg-type-easy/15 flex items-center justify-center text-lg mb-4">&#x1F3C3;</div>
            <h3 class="font-semibold text-lg mb-2">Block Periodization</h3>
            <p class="text-sm text-text-secondary">
              2-3 week training blocks with clear stimulus, goals, and success metrics.
              80/20 polarized approach adapted to your fitness.
            </p>
          </div>
          <div class="rounded-2xl bg-bg-card border border-border-subtle p-6">
            <div class="w-10 h-10 rounded-xl bg-accent/15 flex items-center justify-center text-lg mb-4">&#x1F4CA;</div>
            <h3 class="font-semibold text-lg mb-2">Strava Sync</h3>
            <p class="text-sm text-text-secondary">
              Automatic daily sync from Strava. All activity types — runs, rides,
              swims, yoga, strength. Planned vs actual comparison.
            </p>
          </div>
          <div class="rounded-2xl bg-bg-card border border-border-subtle p-6">
            <div class="w-10 h-10 rounded-xl bg-type-key/15 flex items-center justify-center text-lg mb-4">&#x1F916;</div>
            <h3 class="font-semibold text-lg mb-2">AI Coach</h3>
            <p class="text-sm text-text-secondary">
              Claude-powered plan generation based on your goals, PBs, and
              current fitness. Your coach reviews and approves every block.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-border-subtle text-center text-xs text-text-muted">
      <p>Blockwork — Built for athletes who want structure without rigidity.</p>
    </footer>
  </body>
</html>
