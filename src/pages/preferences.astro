---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMeta } from '../lib/data';
const meta = getMeta();
---

<BaseLayout title="My Training" active="preferences">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-1">My Training Setup</h1>
    <p class="text-text-secondary text-sm mb-8">Set your schedule, goals, and preferences. Coach builds the plan around this.</p>

    <form id="prefForm" class="space-y-6">

      <!-- Weekly Schedule -->
      <div class="card p-6">
        <h2 class="text-base font-semibold mb-1">Weekly Schedule</h2>
        <p class="text-[11px] text-text-muted mb-5">What type of session fits each day? Drag to rearrange later.</p>

        <div class="grid grid-cols-7 gap-2" id="weekGrid">
          {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((day, i) => (
            <div class="text-center">
              <div class="text-[10px] font-bold text-text-muted uppercase tracking-wider mb-2">{day}</div>
              <select
                name={`day_${i}`}
                class="w-full bg-bg-raised border border-border rounded-xl px-2 py-2.5 text-[11px] text-text-primary focus:border-accent focus:outline-none appearance-none text-center"
              >
                <option value="easy">Easy Run</option>
                <option value="key">Key Workout</option>
                <option value="long_run">Long Run</option>
                <option value="long_ride">Long Ride</option>
                <option value="bike">Easy Ride</option>
                <option value="strength">Strength</option>
                <option value="yoga">Yoga/Mobility</option>
                <option value="rest">Rest</option>
                <option value="flexible">Flexible</option>
              </select>
            </div>
          ))}
        </div>

        <div class="mt-4 p-3 rounded-xl bg-bg-main border border-border">
          <div class="text-[10px] text-text-muted mb-1">Quick tip</div>
          <div class="text-[11px] text-text-secondary">Set your long ride/run on days you have the most time. Key workouts need fresh legs — don't put them after long sessions. Rest is flexible — add a recovery ride if you feel like it.</div>
        </div>
      </div>

      <!-- Availability -->
      <div class="card p-6">
        <h2 class="text-base font-semibold mb-4">Weekly Availability</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="section-label block mb-1.5">Running hours/week</label>
            <input name="run_hours" type="number" min="1" max="20" step="0.5" value="5" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary mono focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="section-label block mb-1.5">Cycling hours/week</label>
            <input name="bike_hours" type="number" min="0" max="20" step="0.5" value="3" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary mono focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="section-label block mb-1.5">Max long run (km)</label>
            <input name="max_long_run" type="number" min="5" max="42" value="18" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary mono focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="section-label block mb-1.5">Max long ride (hours)</label>
            <input name="max_long_ride" type="number" min="1" max="6" step="0.5" value="2.5" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary mono focus:border-accent focus:outline-none" />
          </div>
        </div>
      </div>

      <!-- Goals -->
      <div class="card p-6">
        <h2 class="text-base font-semibold mb-4">Goals</h2>
        <div class="space-y-4">
          <div>
            <label class="section-label block mb-1.5">Short-term goal (next 2-3 months)</label>
            <input name="short_goal" placeholder="e.g. Sub-17 min 5K" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="section-label block mb-1.5">Long-term goal (6-12 months)</label>
            <input name="long_goal" placeholder="e.g. Sub-36 min 10K, sub-2:50 marathon" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="section-label block mb-1.5">Next target race (if any)</label>
            <input name="target_race" placeholder="e.g. Paphos 10K - October 2026" class="w-full bg-bg-raised border border-border rounded-xl px-3 py-2.5 text-sm text-text-primary focus:border-accent focus:outline-none" />
          </div>
        </div>
      </div>

      <!-- Coach Notes -->
      <div class="card p-6">
        <h2 class="text-base font-semibold mb-4">Notes for Coach</h2>
        <textarea name="notes" rows="4" placeholder="Anything the coach should know: injuries, schedule constraints, race history, what worked before, what didn't..." class="w-full bg-bg-raised border border-border rounded-xl px-3 py-3 text-sm text-text-primary focus:border-accent focus:outline-none resize-none"></textarea>
      </div>

      <!-- Save -->
      <button type="submit" id="saveBtn" class="w-full py-3.5 rounded-2xl bg-accent text-bg-deep font-semibold text-sm hover:shadow-[0_0_30px_rgba(0,229,176,0.2)] transition-all">
        Save Preferences
      </button>

      <div id="status" class="text-center text-sm"></div>
    </form>
  </div>

  <script is:inline>
    // Auth check
    try {
      var u = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
      if (!u.email || u.exp < Date.now()) window.location.href = '/';
    } catch(e) { window.location.href = '/'; }

    // Load saved preferences
    var saved = JSON.parse(localStorage.getItem('blockwork_preferences') || '{}');
    if (saved.schedule) {
      var selects = document.querySelectorAll('#weekGrid select');
      selects.forEach(function(sel, i) { if (saved.schedule[i]) sel.value = saved.schedule[i]; });
    }
    if (saved.run_hours) document.querySelector('[name=run_hours]').value = saved.run_hours;
    if (saved.bike_hours) document.querySelector('[name=bike_hours]').value = saved.bike_hours;
    if (saved.max_long_run) document.querySelector('[name=max_long_run]').value = saved.max_long_run;
    if (saved.max_long_ride) document.querySelector('[name=max_long_ride]').value = saved.max_long_ride;
    if (saved.short_goal) document.querySelector('[name=short_goal]').value = saved.short_goal;
    if (saved.long_goal) document.querySelector('[name=long_goal]').value = saved.long_goal;
    if (saved.target_race) document.querySelector('[name=target_race]').value = saved.target_race;
    if (saved.notes) document.querySelector('[name=notes]').value = saved.notes;

    // Save
    document.getElementById('prefForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var selects = document.querySelectorAll('#weekGrid select');
      var schedule = [];
      selects.forEach(function(sel) { schedule.push(sel.value); });

      var prefs = {
        schedule: schedule,
        run_hours: parseFloat(document.querySelector('[name=run_hours]').value),
        bike_hours: parseFloat(document.querySelector('[name=bike_hours]').value),
        max_long_run: parseInt(document.querySelector('[name=max_long_run]').value),
        max_long_ride: parseFloat(document.querySelector('[name=max_long_ride]').value),
        short_goal: document.querySelector('[name=short_goal]').value,
        long_goal: document.querySelector('[name=long_goal]').value,
        target_race: document.querySelector('[name=target_race]').value,
        notes: document.querySelector('[name=notes]').value,
        updated: new Date().toISOString(),
      };

      localStorage.setItem('blockwork_preferences', JSON.stringify(prefs));

      // Also save to D1 via API
      var user = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
      if (user.email) {
        fetch('/api/preferences', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: user.email, preferences: prefs }),
        }).catch(function() {});
      }

      var btn = document.getElementById('saveBtn');
      btn.textContent = 'Saved!';
      btn.style.background = '#0be881';
      setTimeout(function() {
        btn.textContent = 'Save Preferences';
        btn.style.background = '';
      }, 2000);

      var st = document.getElementById('status');
      st.textContent = 'Preferences saved. Your coach will use these for the next block.';
      st.style.color = '#0be881';
    });
  </script>
</BaseLayout>
