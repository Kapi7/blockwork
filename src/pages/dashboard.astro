---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMeta, getCurrentBlock, getFitness, getRecentRuns, getCalendarDays, getTrainingLoad } from '../lib/data';
import { formatPace, formatSpeed, formatEffort, formatDate, formatDistance, formatTime } from '../lib/format';
import { PHASE_COLORS, TYPE_COLORS } from '../lib/types';

const meta = getMeta();
const block = getCurrentBlock();
const fitness = getFitness();
const recentRuns = getRecentRuns(6);
const phaseColor = PHASE_COLORS[meta.currentPhase] || '#485460';
const tl = getTrainingLoad();

const today = new Date().toISOString().slice(0, 10);
const upcomingSessions = block?.sessions.filter((s) => s.date >= today).slice(0, 4) || [];

const calDays = getCalendarDays(1);
const todayIdx = calDays.findIndex((d) => d.date === today);
const weekStart = todayIdx >= 0 ? todayIdx - ((new Date(today).getDay() + 6) % 7) : 0;
const currentWeek = calDays.slice(Math.max(0, weekStart), Math.max(0, weekStart) + 7);

const SPORT_ICONS: Record<string, string> = { run: '\u{1F3C3}', bike: '\u{1F6B4}', swim: '\u{1F3CA}', yoga: '\u{1F9D8}', strength: '\u{1F4AA}', hike: '\u26F0', other: '\u2B50' } as any;
---

<BaseLayout title="Dashboard" active="dashboard">
  <!-- Status Hero -->
  <div class="grid lg:grid-cols-[1fr_auto] gap-5 mb-6">
    <!-- Left: Training Status -->
    <div class="card p-6">
      <div class="flex items-start justify-between mb-5">
        <div>
          <div class="section-label mb-2">Training Status</div>
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full pulse" style={`background: ${tl.current.statusColor};`}></div>
            <span class="text-2xl font-bold capitalize" style={`color: ${tl.current.statusColor};`}>{tl.current.status}</span>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="px-3 py-1 rounded-full text-[10px] font-bold tracking-[0.1em] uppercase" style={`background: ${phaseColor}12; color: ${phaseColor}; border: 1px solid ${phaseColor}25;`}>
            {meta.currentPhase}
          </span>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <div class="section-label">Fatigue</div>
          <div class="stat-value text-3xl mt-1 text-text-primary">{tl.current.atl}</div>
          <div class="text-[10px] text-text-muted mt-0.5">ATL · 7 day</div>
        </div>
        <div>
          <div class="section-label">Fitness</div>
          <div class="stat-value text-3xl mt-1 text-text-primary">{tl.current.ctl}</div>
          <div class="text-[10px] text-text-muted mt-0.5">CTL · 42 day</div>
        </div>
        <div>
          <div class="section-label">Form</div>
          <div class="stat-value text-3xl mt-1" style={`color: ${tl.current.statusColor};`}>{tl.current.tsb > 0 ? '+' : ''}{tl.current.tsb}</div>
          <div class="text-[10px] text-text-muted mt-0.5">TSB · freshness</div>
        </div>
      </div>
    </div>

    <!-- Right: Volume + Goals -->
    <div class="flex flex-col gap-3 w-full lg:w-[260px]">
      <div class="card-sm p-4 flex-1">
        <div class="section-label mb-2">This Week</div>
        <div class="stat-value text-2xl" style="color:#00e5b0;">{fitness.volume7d}<span class="text-xs text-text-muted font-normal ml-1">km</span></div>
        <div class="text-[10px] text-text-muted mt-1">{fitness.runs7d} sessions</div>
      </div>
      <div class="card-sm p-4 flex-1">
        <div class="section-label mb-2">28-Day Load</div>
        <div class="stat-value text-2xl">{fitness.volume28d}<span class="text-xs text-text-muted font-normal ml-1">km</span></div>
        <div class="text-[10px] text-text-muted mt-1">{fitness.runs28d} sessions · avg {formatPace(fitness.avgPace28d)}</div>
      </div>
      {meta.goals[0] && (
        <div class="card-sm p-4 flex-1" style={`border-left: 3px solid #00e5b0;`}>
          <div class="section-label mb-1">{meta.goals[0].goal}</div>
          <div class="stat-value text-xl" style="color:#00e5b0;">{meta.goals[0].target}</div>
          <div class="text-[10px] text-text-muted mt-1">{meta.goals[0].timeline}</div>
        </div>
      )}
    </div>
  </div>

  <!-- Week Strip -->
  <div class="card p-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <span class="section-label">This Week</span>
      <a href="/calendar" class="text-[11px] text-accent hover:underline font-medium">View Calendar &rarr;</a>
    </div>
    <div class="grid grid-cols-7 gap-2">
      {currentWeek.map((day) => {
        const isToday = day.date === today;
        const typeColor = day.session ? (TYPE_COLORS[day.session.type] || '#485460') : 'transparent';
        const dayName = new Date(day.date + 'T00:00:00').toLocaleDateString('en-GB', { weekday: 'short' });
        const dayNum = new Date(day.date + 'T00:00:00').getDate();
        const matched = day.session?.actual;
        const isPast = day.date < today;
        const missed = day.session && isPast && !matched && day.session.type !== 'rest';
        const hasActivity = day.activities.length > 0;

        return (
          <a href="/calendar" class:list={[
            'rounded-2xl p-3 text-center border transition-all group',
            isToday ? 'border-accent/25 bg-accent/[0.04] glow-sm' : 'border-border bg-bg-card/30 hover:bg-bg-card/60',
          ]}>
            <div class="text-[10px] font-semibold text-text-muted tracking-wider uppercase">{dayName}</div>
            <div class:list={['text-lg font-bold mt-0.5', isToday ? 'text-accent' : 'text-text-secondary']}>{dayNum}</div>

            {day.session && (
              <div class="mt-2">
                <div class="h-[3px] rounded-full mx-auto w-8" style={`background: ${typeColor};`}></div>
                <div class="text-[9px] font-semibold mt-1.5 truncate" style={`color: ${typeColor};`}>{day.session.planned.desc}</div>
              </div>
            )}

            {matched && (
              <div class="text-[10px] mono text-type-easy mt-1">{formatDistance(matched.dist)}km</div>
            )}

            {!day.session && hasActivity && (
              <div class="mt-2">
                {day.activities.slice(0, 1).map((a) => (
                  <div class="text-[10px] mono text-text-secondary">{formatDistance(a.dist)}km</div>
                ))}
              </div>
            )}

            {missed && <div class="text-[9px] text-type-key/50 mt-1">missed</div>}
          </a>
        );
      })}
    </div>
  </div>

  <!-- Upcoming + Recent side by side -->
  <div class="grid lg:grid-cols-2 gap-5">
    <!-- Upcoming Sessions -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4">
        <span class="section-label">Upcoming</span>
        {block && <a href={`/blocks/${block.id}`} class="text-[11px] text-accent hover:underline font-medium">Block details &rarr;</a>}
      </div>
      {upcomingSessions.length > 0 ? (
        <div class="space-y-2">
          {upcomingSessions.map((s) => {
            const tc = TYPE_COLORS[s.type] || '#485460';
            return (
              <div class="flex items-center gap-3 p-3 rounded-xl bg-bg-main/40 border border-border group hover:border-border-light transition-colors">
                <div class="sport-line" style={`background: ${tc};`}></div>
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] font-semibold">{s.planned.desc}</div>
                  <div class="text-[11px] text-text-muted mt-0.5">
                    {formatDate(s.date)}
                    {s.planned.distance > 0 && ` \u00B7 ${s.planned.distance}km`}
                    {s.planned.pace && ` \u00B7 ${s.planned.pace}`}
                  </div>
                </div>
                <span class="text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider" style={`background: ${tc}10; color: ${tc};`}>{s.type}</span>
              </div>
            );
          })}
        </div>
      ) : (
        <p class="text-sm text-text-muted py-4 text-center">No upcoming sessions</p>
      )}
    </div>

    <!-- Recent Activity -->
    <div class="card p-5">
      <span class="section-label">Recent Activity</span>
      <div class="mt-4 space-y-1">
        {recentRuns.map((r) => {
          const sportIcon = SPORT_ICONS[r.sport] || '\u2B50';
          return (
            <div class="flex items-center gap-3 py-2.5 px-2 rounded-lg hover:bg-bg-raised/50 transition-colors">
              <span class="text-sm">{sportIcon}</span>
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-medium truncate">{r.name}</div>
                <div class="text-[10px] text-text-muted">{formatDate(r.date)}</div>
              </div>
              <div class="text-right">
                <div class="text-[12px] mono font-semibold">{r.dist > 0 ? `${formatDistance(r.dist)}km` : formatTime(r.time)}</div>
                {r.pace > 0 && r.pace < 600 && (
                  <div class="text-[10px] mono" style={`color: ${r.sport === 'bike' ? '#3498ff' : r.pace < 250 ? '#f53b57' : r.pace < 300 ? '#ffb142' : '#0be881'};`}>
                    {r.sport === 'bike' ? formatSpeed(r.pace) : formatPace(r.pace)}
                  </div>
                )}
              </div>
              {r.hr > 0 && (
                <div class="text-[10px] mono text-text-muted w-8 text-right">{Math.round(r.hr)}</div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <script is:inline>
    try {
      var u = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
      if (!u.email || u.exp < Date.now()) window.location.href = '/';
    } catch(e) { window.location.href = '/'; }
  </script>
</BaseLayout>
