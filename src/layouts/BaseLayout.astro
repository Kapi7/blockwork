---
import '../styles/global.css';

interface Props {
  title: string;
  active?: string;
}

const { title, active = '' } = Astro.props;

const nav = [
  { href: '/dashboard', label: 'Dashboard', id: 'dashboard' },
  { href: '/calendar', label: 'Calendar', id: 'calendar' },
  { href: '/blocks', label: 'Blocks', id: 'blocks' },
  { href: '/analytics', label: 'Analytics', id: 'analytics' },
  { href: '/races', label: 'Races', id: 'races' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Blockwork</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen noise">
    <!-- Nav -->
    <nav class="fixed top-0 inset-x-0 z-50 bg-bg-deep/70 backdrop-blur-2xl border-b border-border">
      <div class="mx-auto max-w-[1400px] px-5">
        <div class="flex h-[52px] items-center justify-between">
          <a href="/" class="flex items-center gap-2">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="2" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.9"/>
              <rect x="14" y="2" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.4"/>
              <rect x="2" y="14" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.4"/>
              <rect x="14" y="14" width="8" height="8" rx="2" fill="#00e5b0" opacity="0.15"/>
            </svg>
            <span class="text-[15px] font-bold tracking-tight text-text-primary">blockwork</span>
          </a>

          <div class="hidden sm:flex items-center gap-0.5 bg-bg-card/60 rounded-xl px-1 py-1">
            {nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'px-3.5 py-1.5 rounded-lg text-[12px] font-medium transition-all',
                  active === item.id
                    ? 'bg-accent/10 text-accent shadow-sm'
                    : 'text-text-secondary hover:text-text-primary',
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>

          <div class="flex items-center gap-3" id="navUser">
            <div class="w-7 h-7 rounded-full bg-bg-raised border border-border" id="navAvatar"></div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile nav -->
    <nav class="sm:hidden fixed bottom-0 inset-x-0 z-50 bg-bg-deep/80 backdrop-blur-2xl border-t border-border safe-b">
      <div class="flex items-center justify-around py-2 px-2">
        {nav.slice(0, 5).map((item) => (
          <a
            href={item.href}
            class:list={[
              'flex flex-col items-center gap-0.5 py-1.5 px-2 rounded-xl transition-colors',
              active === item.id ? 'text-accent' : 'text-text-muted',
            ]}
          >
            <span class="text-[11px] font-medium">{item.label}</span>
          </a>
        ))}
      </div>
    </nav>

    <main class="mx-auto max-w-[1400px] px-5 pt-[68px] pb-28 sm:pb-8">
      <slot />
    </main>

    <script is:inline>
      // Load user avatar in nav
      try {
        var u = JSON.parse(localStorage.getItem('blockwork_user') || '{}');
        if (u.picture) {
          var av = document.getElementById('navAvatar');
          if (av) {
            var img = document.createElement('img');
            img.src = u.picture;
            img.className = 'w-7 h-7 rounded-full';
            img.referrerPolicy = 'no-referrer';
            av.replaceWith(img);
          }
        }
      } catch(e) {}
    </script>
  </body>
</html>
