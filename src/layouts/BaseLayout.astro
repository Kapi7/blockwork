---
import '../styles/global.css';

interface Props {
  title: string;
  active?: string;
}

const { title, active = '' } = Astro.props;

const nav = [
  { href: '/dashboard', label: 'Dashboard', id: 'dashboard', icon: '\u2302' },
  { href: '/calendar', label: 'Calendar', id: 'calendar', icon: '\u{1F4C5}' },
  { href: '/blocks', label: 'Blocks', id: 'blocks', icon: '\u{1F9F1}' },
  { href: '/analytics', label: 'Analytics', id: 'analytics', icon: '\u{1F4CA}' },
  { href: '/races', label: 'Races', id: 'races', icon: '\u{1F3C6}' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Blockwork</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-bg-main">
    <!-- Top nav -->
    <nav class="fixed top-0 inset-x-0 z-50 border-b border-border-subtle bg-bg-main/80 backdrop-blur-xl">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="flex h-14 items-center justify-between">
          <a href="/" class="flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-lg bg-accent/20 flex items-center justify-center">
              <div class="w-3 h-3 rounded-sm bg-accent"></div>
            </div>
            <span class="text-base font-bold tracking-tight">
              <span class="text-accent">BLOCK</span><span class="text-text-primary">WORK</span>
            </span>
          </a>

          <div class="hidden sm:flex items-center gap-0.5">
            {nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'px-3.5 py-1.5 rounded-lg text-[13px] font-medium transition-all',
                  active === item.id
                    ? 'bg-accent/12 text-accent'
                    : 'text-text-secondary hover:text-text-primary hover:bg-white/[0.03]',
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>

          <div class="flex items-center gap-3" id="userArea">
            <a href="/" class="text-xs text-text-muted hover:text-text-secondary transition-colors">Logout</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile bottom nav -->
    <nav class="sm:hidden fixed bottom-0 inset-x-0 z-50 border-t border-border-subtle bg-bg-main/90 backdrop-blur-xl">
      <div class="flex items-center justify-around py-2">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors',
              active === item.id ? 'text-accent' : 'text-text-muted',
            ]}
          >
            <span class="text-lg">{item.icon}</span>
            <span class="text-[10px] font-medium">{item.label}</span>
          </a>
        ))}
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-4 pt-20 pb-24 sm:pb-8 sm:px-6">
      <slot />
    </main>
  </body>
</html>
