---
interface Props {
  color: string;
  text: string;
  size?: 'sm' | 'md';
}

const { color, text, size = 'sm' } = Astro.props;
const classes = size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-3 py-1 text-sm';
---

<span
  class:list={['inline-flex items-center rounded-full font-medium', classes]}
  style={`background: ${color}20; color: ${color}; border: 1px solid ${color}40;`}
>
  {text}
</span>
