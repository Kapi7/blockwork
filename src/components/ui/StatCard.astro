---
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  color?: string;
}

const { label, value, sub, color } = Astro.props;
---

<div class="stat-card">
  <div class="stat-card-inner">
    <p class="text-[10px] font-semibold uppercase tracking-wider text-text-muted mb-1.5">{label}</p>
    <p class="text-xl font-bold font-mono" style={color ? `color: ${color}` : ''}>{value}</p>
    {sub && <p class="text-[10px] text-text-muted mt-0.5">{sub}</p>}
  </div>
</div>
