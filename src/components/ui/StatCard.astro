---
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  color?: string;
}

const { label, value, sub, color } = Astro.props;
---

<div class="rounded-lg bg-bg-card p-4 border border-border-subtle">
  <p class="text-xs font-medium uppercase tracking-wider text-text-muted mb-1">{label}</p>
  <p class="text-2xl font-bold font-mono" style={color ? `color: ${color}` : ''}>{value}</p>
  {sub && <p class="text-xs text-text-secondary mt-0.5">{sub}</p>}
</div>
